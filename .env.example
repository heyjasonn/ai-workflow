# Orchestration provider
# Values: stub | openai | codex-cli | cursor-cli | claude-cli
LLM_PROVIDER=codex-cli

# Codex CLI adapter
CODEX_CLI_COMMAND=codex
# Optional, space-separated args passed to command.
# If empty, default is: exec -
CODEX_CLI_ARGS=

# Cursor CLI adapter (optional)
CURSOR_CLI_COMMAND=cursor
CURSOR_CLI_ARGS=

# Claude CLI adapter (optional)
CLAUDE_CLI_COMMAND=claude
CLAUDE_CLI_ARGS=

# OpenAI adapter (optional)
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_API_BASE=

# Optional DB config used by legacy workflow engine
DATABASE_URL=
