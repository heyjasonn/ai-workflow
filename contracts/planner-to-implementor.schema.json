{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "planner-to-implementor.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "architecture_overview",
    "request_flow",
    "api_contract",
    "db_changes",
    "implementation_steps",
    "constraints",
    "assumptions"
  ],
  "properties": {
    "architecture_overview": { "type": "string", "minLength": 1 },
    "request_flow": { "type": "array", "items": { "type": "string" } },
    "api_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "path",
        "request_fields",
        "response_fields",
        "error_contract",
        "backward_compatibility"
      ],
      "properties": {
        "method": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "request_fields": { "type": "array", "items": { "type": "string" } },
        "response_fields": { "type": "array", "items": { "type": "string" } },
        "error_contract": { "type": "array", "items": { "type": "string" } },
        "backward_compatibility": { "type": "string", "minLength": 1 }
      }
    },
    "db_changes": { "type": "array", "items": { "type": "string" } },
    "implementation_steps": { "type": "array", "items": { "type": "string" } },
    "constraints": { "type": "array", "items": { "type": "string" } },
    "assumptions": { "type": "array", "items": { "type": "string" } }
  }
}
