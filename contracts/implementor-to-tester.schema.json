{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "implementor-to-tester.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "changed_files",
    "implemented_rules",
    "known_limitations",
    "areas_needing_tests",
    "integration_points"
  ],
  "properties": {
    "changed_files": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "implemented_rules": { "type": "array", "items": { "type": "string" } },
    "known_limitations": { "type": "array", "items": { "type": "string" } },
    "areas_needing_tests": { "type": "array", "items": { "type": "string" } },
    "integration_points": { "type": "array", "items": { "type": "string" } }
  }
}
